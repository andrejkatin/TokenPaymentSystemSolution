        }
      },
      "withdraw-route": {
        "ClusterId": "transaction-cluster",
        "AuthorizationPolicy": "admin",
        "Match": {
          "Path": "transaction/withdraw",
          "Methods": [ "POST" ]
        }
      }
    },
    "Clusters": {
      "wallet-cluster": {
